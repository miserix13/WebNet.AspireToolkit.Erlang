{application, hello_erlang,
    [
        {description, "Sample Erlang app for testing the Aspire Erlang integration"},
        {vsn, "0.1.0"},
        {registered, [hello_erlang_server]},
        {mod, {hello_erlang_app, []}},
        {applications, [kernel, stdlib]},
        {modules, [
            hello_erlang_app,
            hello_erlang_sup,
            hello_erlang_server
        ]}
    ]}.
